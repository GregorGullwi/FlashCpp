63:// Parse a single template parameter: typename T, class T, int N, etc.
64:ParseResult Parser::parse_template_parameter() {
65:	ScopedTokenPosition saved_position(*this);
66:
67:	// Check for template template parameter: template<template<typename> class Container>
68:	if (peek() == "template"_tok) {
69:		[[maybe_unused]] Token template_keyword = peek_info();
70:		advance(); // consume 'template'
71:
72:		// Expect '<' to start nested template parameter list
73:		if (peek() != "<"_tok) {
74:			FLASH_LOG(Parser, Error, "Expected '<' after 'template', got: ",
75:					  (!peek().is_eof() ? std::string("'") + std::string(peek_info().value()) + "'" : "<EOF>"));
76:			return ParseResult::error("Expected '<' after 'template' keyword in template template parameter", current_token_);
77:		}
78:		advance(); // consume '<'
79:
80:		// Parse nested template parameter forms (just type specifiers, no names)
81:		std::vector<ASTNode> nested_params;
82:		auto param_list_result = parse_template_template_parameter_forms(nested_params);
83:		if (param_list_result.is_error()) {
84:			FLASH_LOG(Parser, Error, "parse_template_template_parameter_forms failed");
85:			return param_list_result;
86:		}
87:
88:		// Expect '>' to close nested template parameter list
89:		if (peek() != ">"_tok) {
90:			FLASH_LOG(Parser, Error, "Expected '>' after nested template parameter list, got: ",
91:					  (!peek().is_eof() ? std::string("'") + std::string(peek_info().value()) + "'" : "<EOF>"));
92:			return ParseResult::error("Expected '>' after nested template parameter list", current_token_);
93:		}
94:		advance(); // consume '>'
95:
96:		// Expect 'class' or 'typename'
97:		if (!peek().is_keyword() ||
98:			(peek() != "class"_tok && peek() != "typename"_tok)) {
99:			FLASH_LOG(Parser, Error, "Expected 'class' or 'typename' after template parameter list, got: ",
100:					  (!peek().is_eof() ? std::string("'") + std::string(peek_info().value()) + "'" : "<EOF>"));
101:			return ParseResult::error("Expected 'class' or 'typename' after template parameter list in template template parameter", current_token_);
102:		}
103:		advance(); // consume 'class' or 'typename'
104:
105:		// Parameter name is optional (unnamed template template parameters are valid C++)
106:		// e.g., template <class, class, template <class> class, template <class> class>
107:		std::string_view param_name;
108:		Token param_name_token;
109:		if (peek().is_identifier()) {
110:			param_name_token = peek_info();
111:			param_name = param_name_token.value();
112:			advance(); // consume parameter name
113:		} else {
114:			// Generate a unique synthetic name for unnamed template template parameter.
115:			// This avoids collisions when multiple unnamed template template parameters
116:			// appear in the same declaration (e.g., template<template<class> class, template<class> class>).
117:			// Without unique names, substitution maps would overwrite earlier bindings.
118:			static int anonymous_template_template_counter = 0;
119:			param_name = StringBuilder().append("__anon_ttp_"sv).append(static_cast<int64_t>(anonymous_template_template_counter++)).commit();
120:			param_name_token = current_token_;
121:		}
122:
123:		// Create template template parameter node
124:		auto param_node = emplace_node<TemplateParameterNode>(StringTable::getOrInternStringHandle(param_name), std::move(nested_params), param_name_token);
125:
126:		// Handle default arguments (e.g., template<typename> class Container = std::vector)
127:		if (peek() == "="_tok) {
128:			advance(); // consume '='
129:
130:			// Save position for potential SFINAE re-parse of dependent defaults
131:			SaveHandle default_pos = save_token_position();
132:
133:			// Parse the default type.
134:			// parse_type_specifier() handles both simple names (MyContainer) and
135:			// namespace-qualified names (my_ns::NsContainer, std::vector) via
136:			// its qualified identifier resolution infrastructure.
137:			auto default_type_result = parse_type_specifier();
138:			if (default_type_result.is_error()) {
139:				discard_saved_token(default_pos);
140:				return ParseResult::error("Expected type after '=' in template template parameter default", current_token_);
141:			}
142:
143:			if (default_type_result.node().has_value()) {
144:				param_node.as<TemplateParameterNode>().set_default_value(*default_type_result.node());
145:				param_node.as<TemplateParameterNode>().set_default_value_position(default_pos);
146:			} else {
147:				discard_saved_token(default_pos);
148:			}
149:		}
150:
151:		return saved_position.success(param_node);
152:	}
153:
154:	// Check for concept-constrained type parameter: Concept T, Concept<U> T, namespace::Concept T
155:	if (peek().is_identifier()) {
156:		auto concept_check_pos = save_token_position();
157:
158:		// Build potential concept name (possibly namespace-qualified)
159:		StringBuilder potential_concept_sb;
160:		potential_concept_sb.append(peek_info().value());
161:		Token concept_token = peek_info();
162:		advance(); // consume first identifier
163:
164:		// Check for namespace-qualified concept: ns::concept or ns::ns2::concept
165:		while (peek() == "::"_tok) {
166:			advance(); // consume '::'
167:			if (!peek().is_identifier()) {
168:				// Not a valid qualified name, restore and continue
169:				restore_token_position(concept_check_pos);
170:				potential_concept_sb.reset();
171:				break;
172:			}
173:			potential_concept_sb.append("::");
174:			potential_concept_sb.append(peek_info().value());
175:			concept_token = peek_info();
176:			advance(); // consume next identifier
177:		}
178:
179:		// Intern the concept name string and get a stable string_view
180:		StringHandle concept_handle = StringTable::getOrInternStringHandle(potential_concept_sb);
181:		std::string_view potential_concept = StringTable::getStringView(concept_handle);
182:
183:		// Check if this identifier is a registered concept
184:		FLASH_LOG_FORMAT(Parser, Debug, "parse_template_parameter: Checking if '{}' is a concept", potential_concept);
185:		if (gConceptRegistry.hasConcept(potential_concept)) {
186:			FLASH_LOG_FORMAT(Parser, Debug, "parse_template_parameter: '{}' IS a registered concept", potential_concept);
187:			// Check for template arguments: Concept<U>
188:			std::vector<ASTNode> concept_template_args;
189:			if (peek() == "<"_tok) {
190:				advance(); // consume '<'
191:				// Parse concept template arguments as type specifiers
192:				while (peek() != ">"_tok && !peek().is_eof()) {
193:					auto arg_result = parse_type_specifier();
194:					if (!arg_result.is_error() && arg_result.node().has_value()) {
195:						concept_template_args.push_back(*arg_result.node());
196:					} else {
197:						// Skip unrecognized token with a diagnostic
198:						FLASH_LOG_FORMAT(Parser, Warning, "Skipping unrecognized token '{}' in concept template arguments for '{}'",
199:										 !peek().is_eof() ? std::string(peek_info().value()) : "<EOF>", potential_concept);
200:						advance();
201:					}
202:					if (peek() == ","_tok) {
203:						advance(); // consume ','
204:					}
205:				}
206:				if (peek() == ">"_tok) {
207:					advance(); // consume '>'
208:				}
209:			}
210:
211:			// Check for ellipsis (parameter pack): Concept... Ts
212:			bool is_variadic = false;
213:			if (!peek().is_eof() &&
214:				(peek().is_operator() || peek().is_punctuator()) &&
215:				peek() == "..."_tok) {
216:				advance(); // consume '...'
217:				is_variadic = true;
218:			}
219:
220:			// Expect identifier (parameter name)
221:			if (!peek().is_identifier()) {
222:				return ParseResult::error("Expected identifier after concept constraint", current_token_);
223:			}
224:
225:			Token param_name_token = peek_info();
226:			std::string_view param_name = param_name_token.value();
227:			advance(); // consume parameter name
228:
229:			// Create type parameter node (concept-constrained)
230:			auto param_node = emplace_node<TemplateParameterNode>(StringTable::getOrInternStringHandle(param_name), param_name_token);
231:
232:			// Store the concept constraint
233:			param_node.as<TemplateParameterNode>().set_concept_constraint(potential_concept);
234:
235:			// Store concept template arguments if present (e.g., Concept<U> T stores {U})
236:			if (!concept_template_args.empty()) {
237:				param_node.as<TemplateParameterNode>().set_concept_args(std::move(concept_template_args));
238:			}
239:
240:			// Set variadic flag if this is a parameter pack
241:			if (is_variadic) {
242:				param_node.as<TemplateParameterNode>().set_variadic(true);
243:			}
244:
245:			// Handle default arguments (e.g., Concept T = int)
246:			// Note: Parameter packs cannot have default arguments
247:			if (!is_variadic && peek() == "="_tok) {
248:				advance(); // consume '='
249:
250:				// Save position for potential SFINAE re-parse of dependent defaults
251:				SaveHandle default_pos = save_token_position();
252:
253:				// Parse the default type
254:				auto default_type_result = parse_type_specifier();
255:				if (default_type_result.is_error()) {
256:					discard_saved_token(default_pos);
257:					return ParseResult::error("Expected type after '=' in template parameter default", current_token_);
258:				}
259:
260:				if (default_type_result.node().has_value()) {
261:					TypeSpecifierNode& type_spec = default_type_result.node()->as<TypeSpecifierNode>();
262:
263:					// Apply pointer/reference qualifiers (ptr-operator in C++20 grammar)
264:					consume_pointer_ref_modifiers(type_spec);
265:					param_node.as<TemplateParameterNode>().set_default_value(*default_type_result.node());
266:					param_node.as<TemplateParameterNode>().set_default_value_position(default_pos);
267:				} else {
268:					discard_saved_token(default_pos);
269:				}
270:			}
271:
272:			return saved_position.success(param_node);
273:		} else {
274:			// Not a concept, restore position and let other parsing handle it
275:			restore_token_position(concept_check_pos);
276:		}
277:	}
278:
279:	// Check for type parameter: typename or class
280:	if (peek().is_keyword()) {
281:		std::string_view keyword = peek_info().value();
282:
283:		if (keyword == "typename" || keyword == "class") {
284:			[[maybe_unused]] Token keyword_token = peek_info();
285:			advance(); // consume 'typename' or 'class'
286:
287:			// Check for ellipsis (parameter pack): typename... Args
288:			bool is_variadic = false;
289:			if (!peek().is_eof() &&
290:				(peek().is_operator() || peek().is_punctuator()) &&
291:				peek() == "..."_tok) {
292:				advance(); // consume '...'
293:				is_variadic = true;
294:			}
295:
296:			// Check for identifier (parameter name) - it's optional for anonymous parameters
297:			std::string_view param_name;
298:			Token param_name_token;
299:
300:			if (peek().is_identifier()) {
301:				// Named parameter
302:				param_name_token = peek_info();
303:				param_name = param_name_token.value();
304:				advance(); // consume parameter name
305:			} else {
306:				// Anonymous parameter - generate unique name
307:				// Check if next token is valid for end of parameter (comma, >, or =)
308:				if (!peek().is_eof() &&
309:					((peek().is_punctuator() && peek() == ","_tok) ||
310:					 (peek().is_operator() && (peek() == ">"_tok || peek() == "="_tok)))) {
311:					// Generate unique anonymous parameter name
312:					static int anonymous_type_counter = 0;
313:					param_name = StringBuilder().append("__anon_type_"sv).append(static_cast<int64_t>(anonymous_type_counter++)).commit();
314:
315:					// Use the current token as the token reference
316:					param_name_token = current_token_;
317:				} else {
318:					return ParseResult::error("Expected identifier after 'typename' or 'class'", current_token_);
319:				}
320:			}
321:
322:			// Create type parameter node
323:			auto param_node = emplace_node<TemplateParameterNode>(StringTable::getOrInternStringHandle(param_name), param_name_token);
324:
325:			// Set variadic flag if this is a parameter pack
326:			if (is_variadic) {
327:				param_node.as<TemplateParameterNode>().set_variadic(true);
328:			}
329:
330:			// Handle default arguments (e.g., typename T = int)
331:			// Note: Parameter packs cannot have default arguments
332:			if (!is_variadic && peek() == "="_tok) {
333:				advance(); // consume '='
334:
335:				// Save position for potential SFINAE re-parse of dependent defaults
336:				SaveHandle default_pos = save_token_position();
337:
338:				// Parse the default type
339:				auto default_type_result = parse_type_specifier();
340:				if (default_type_result.is_error()) {
341:					discard_saved_token(default_pos);
342:					return ParseResult::error("Expected type after '=' in template parameter default", current_token_);
343:				}
344:
345:				if (default_type_result.node().has_value()) {
346:					TypeSpecifierNode& type_spec = default_type_result.node()->as<TypeSpecifierNode>();
347:
348:					// Apply pointer/reference qualifiers (ptr-operator in C++20 grammar)
349:					consume_pointer_ref_modifiers(type_spec);
350:					param_node.as<TemplateParameterNode>().set_default_value(*default_type_result.node());
351:					param_node.as<TemplateParameterNode>().set_default_value_position(default_pos);
352:				} else {
353:					discard_saved_token(default_pos);
354:				}
355:			}
356:
357:			return saved_position.success(param_node);
358:		}
359:	}
360:
361:	// Check for non-type parameter: int N, bool B, etc.
362:	// Parse type specifier
363:	auto type_result = parse_type_specifier();
364:	if (type_result.is_error()) {
365:		return type_result;
366:	}
367:
368:	if (!type_result.node().has_value()) {
369:		return ParseResult::error("Expected type specifier for non-type template parameter", current_token_);
370:	}
371:
372:	// Check for ellipsis (parameter pack): int... Ns
373:	bool is_variadic = false;
374:	if (!peek().is_eof() &&
375:		(peek().is_operator() || peek().is_punctuator()) &&
376:		peek() == "..."_tok) {
377:		advance(); // consume '...'
378:		is_variadic = true;
379:	}
380:	// Check for identifier (parameter name) - it's optional for anonymous parameters
381:	std::string_view param_name;
382:	Token param_name_token;
383:	[[maybe_unused]] bool is_anonymous = false;
384:
385:	if (peek().is_identifier()) {
386:		// Named parameter
387:		param_name_token = peek_info();
388:		param_name = param_name_token.value();
389:		advance(); // consume parameter name
390:	} else {
391:		// Anonymous parameter - generate unique name
392:		// Check if next token is valid for end of parameter (comma, >, or =)
393:		if (!peek().is_eof() &&
394:			((peek().is_punctuator() && peek() == ","_tok) ||
395:			 (peek().is_operator() && (peek() == ">"_tok || peek() == "="_tok)))) {
396:			// Generate unique anonymous parameter name
397:			static int anonymous_counter = 0;
398:			param_name = StringBuilder().append("__anon_param_"sv).append(static_cast<int64_t>(anonymous_counter++)).commit();
399:
400:			// Store the anonymous name in a way that persists
401:			// We'll use the current token as the token reference
402:			param_name_token = current_token_;
403:			is_anonymous = true;
404:		} else {
405:			return ParseResult::error("Expected identifier for non-type template parameter", current_token_);
406:		}
407:	}
408:
409:	// Create non-type parameter node
410:	auto param_node = emplace_node<TemplateParameterNode>(StringTable::getOrInternStringHandle(param_name), *type_result.node(), param_name_token);
411:
412:	// Set variadic flag if this is a parameter pack
413:	if (is_variadic) {
414:		param_node.as<TemplateParameterNode>().set_variadic(true);
415:	}
416:
417:	// Handle default arguments (e.g., int N = 10, size_t M = sizeof(T))
418:	// Note: Parameter packs cannot have default arguments
419:	if (!is_variadic && peek() == "="_tok) {
420:		advance(); // consume '='
421:
422:		// Save position for potential SFINAE re-parse of dependent defaults
