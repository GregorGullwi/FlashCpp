446:ParseResult Parser::parse_template_template_parameter_forms(std::vector<ASTNode>& out_params) {
447:	// Parse first parameter form
448:	auto param_result = parse_template_template_parameter_form();
449:	if (param_result.is_error()) {
450:		return param_result;
451:	}
452:
453:	if (param_result.node().has_value()) {
454:		out_params.push_back(*param_result.node());
455:	}
456:
457:	// Parse additional parameter forms separated by commas
458:	while (peek() == ","_tok) {
459:		advance(); // consume ','
460:
461:		param_result = parse_template_template_parameter_form();
462:		if (param_result.is_error()) {
463:			return param_result;
464:		}
465:
466:		if (param_result.node().has_value()) {
467:			out_params.push_back(*param_result.node());
468:		}
469:	}
470:
471:	return ParseResult::success();
