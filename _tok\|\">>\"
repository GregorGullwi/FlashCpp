474:// Parse a single template template parameter form (just type specifier, no name)
475:// For template<template<typename> class Container>, this parses "typename"
476:// Also handles variadic packs: template<typename...> class Container
477:// Also handles nested template template parameters: template<template<typename> class> class TTT
478:ParseResult Parser::parse_template_template_parameter_form() {
479:	ScopedTokenPosition saved_position(*this);
480:
481:	// Handle nested template template parameter: template<template<typename> class> class TTT
482:	if (peek().is_keyword() && peek() == "template"_tok) {
483:		return saved_position.propagate(parse_template_parameter());
484:	}
485:
486:	// Only support typename and class for now (no non-type parameters in template template parameters)
487:	if (peek().is_keyword()) {
488:		std::string_view keyword = peek_info().value();
489:
490:		if (keyword == "typename" || keyword == "class") {
491:			Token keyword_token = peek_info();
492:			advance(); // consume 'typename' or 'class'
493:
494:			// Check for ellipsis (parameter pack): typename...
495:			// This handles patterns like: template<typename...> class Op
496:			bool is_variadic = false;
497:			if (!peek().is_eof() &&
498:				(peek().is_operator() || peek().is_punctuator()) &&
499:				peek() == "..."_tok) {
500:				advance(); // consume '...'
501:				is_variadic = true;
502:			}
503:
504:			// For template template parameters, we don't expect an identifier name
505:			// Just create a type parameter node with an empty name
506:			auto param_node = emplace_node<TemplateParameterNode>(StringHandle(), keyword_token);
507:
508:			// Set variadic flag if this is a parameter pack
509:			if (is_variadic) {
510:				param_node.as<TemplateParameterNode>().set_variadic(true);
511:			}
512:
513:			return saved_position.success(param_node);
514:		}
515:	}
516:
517:	return ParseResult::error("Expected 'typename' or 'class' in template template parameter form", current_token_);
518:}
