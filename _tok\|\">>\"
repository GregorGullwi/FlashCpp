8:ParseResult Parser::parse_template_parameter_list(InlineVector<ASTNode, 4>& out_params) {
9:	// Save the current template parameter names so we can restore them later.
10:	// This allows nested template declarations to have their own parameter scope.
11:	InlineVector<StringHandle, 4> saved_template_param_names = current_template_param_names_;
12:
13:	// Parse first parameter
14:	auto param_result = parse_template_parameter();
15:	if (param_result.is_error()) {
16:		current_template_param_names_ = std::move(saved_template_param_names);
17:		return param_result;
18:	}
19:
20:	if (param_result.node().has_value()) {
21:		out_params.push_back(*param_result.node());
22:		// Add this parameter's name to current_template_param_names_ so that
23:		// subsequent parameters can reference it in their default values.
24:		// This enables patterns like: template<typename T, bool = is_arithmetic<T>::value>
25:		if (param_result.node()->is<TemplateParameterNode>()) {
26:			const auto& tparam = param_result.node()->as<TemplateParameterNode>();
27:			current_template_param_names_.push_back(tparam.nameHandle());
28:			FLASH_LOG(Templates, Debug, "Added template parameter '", tparam.name(),
29:					  "' to current_template_param_names_ (now has ", current_template_param_names_.size(), " params)");
30:		}
31:	}
32:
33:	// Parse additional parameters separated by commas
34:	while (peek() == ","_tok) {
35:		advance(); // consume ','
36:
37:		param_result = parse_template_parameter();
38:		if (param_result.is_error()) {
39:			current_template_param_names_ = std::move(saved_template_param_names);
40:			return param_result;
41:		}
42:
43:		if (param_result.node().has_value()) {
44:			out_params.push_back(*param_result.node());
45:			// Add this parameter's name too
46:			if (param_result.node()->is<TemplateParameterNode>()) {
47:				const auto& tparam = param_result.node()->as<TemplateParameterNode>();
48:				current_template_param_names_.push_back(tparam.nameHandle());
49:				FLASH_LOG(Templates, Debug, "Added template parameter '", tparam.name(),
50:						  "' to current_template_param_names_ (now has ", current_template_param_names_.size(), " params)");
51:			}
52:		}
53:	}
54:
55:	// Restore the original template parameter names.
56:	// The caller (parse_template_declaration) will set current_template_param_names_
57:	// to the full list of parameters for the body parsing phase.
58:	current_template_param_names_ = std::move(saved_template_param_names);
59:
60:	return ParseResult::success();
61:}
